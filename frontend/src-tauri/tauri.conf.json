{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetPro",
  "version": "1.0.0",
  "identifier": "com.netpro.engine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NetPro Engine",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Sistema de diseño y simulación de topologías de red",
    "longDescription": "NetPro Engine: diseño, versionado y simulación de topologías de red con backend FastAPI/PostgreSQL.",
    "copyright": "© 2026 NetPro Team",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
